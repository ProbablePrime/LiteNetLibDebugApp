{
  "AppOptions": {
    "ClientEnabled": true,
    "ServerEnabled": true
  },
  "ServerServiceOptions": {
    "LocalPort": 22110,

    "DisconnectTimeout": 30000,
    "UseNativeSockets": true,
    "ChannelCount": 2,
    "UpdateTime": 5
  },
  "ClientServiceOptions": {
    "LocalPort": 22111,

    "RemotePort": 22110,
    "RemoteAddress": "127.0.0.1",

    "DisconnectTimeout": 30000,
    "UseNativeSockets": true,
    "ChannelCount": 2,
    "UpdateTime": 5
  },
  "Logging": {
    "Console": {
      "FormatterName": "Simple",
      "FormatterOptions": {
        "SingleLine": true,
        "TimestampFormat": "HH:mm:ss ",
        "IncludeScopes": false,
        "UseUtcTimestamp": false
      },
      "LogLevel": {
        "Default": "Trace"
      }
    },
    "File": {
      "Path": "Logs/app.log",
      "Append": true,
      "MinLevel": "Trace",
      "FileSizeLimitBytes": 1000000,
      "MaxRollingFiles": 10,
      "LogLevel": {
        "Default": "Trace"
      }
    }
  }
}